# ─── Supabase (Frontend — safe to expose, only used for auth) ─────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ_your_anon_key_here

# ─── Supabase Admin (API Server — NEVER expose to frontend) ──────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ_your_service_role_key_here

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# Get these from Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# Create a "Web application" client and add your redirect URIs:
#   Dev:  http://localhost:3000/api/auth/google/callback
#   Prod: https://<your-api-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Frontend URL — used to redirect back after OAuth (dev default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# ─── Cloudflare R2 (optional — for public PDF hosting) ───────────────────────
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=certificates
# Public base URL for your R2 bucket (no trailing slash)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# Public base URL for QR code verification links (no trailing slash)
# Set this to your deployed frontend URL so QR codes point to the right domain
PUBLIC_BASE_URL=http://localhost:5173

# Optional: exact column name in your sheet that contains the phone number
# If not set, auto-detects columns named: phone, phonenumber, mobile, etc.
# R2_PHONE_COLUMN=Phone

# ─── WhatsApp Business Cloud API ─────────────────────────────────────────────
# Template used: document_senderv2 — "Hi {{1}}, your certificate for {{2}} is attached below"
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
# Language code for the template (default: en)
# WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ─── Cashfree Payment Gateway ────────────────────────────────────────────────
# Toggle between PRODUCTION and SANDBOX
VITE_CASHFREE_ENV=SANDBOX
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# ─── Billing Configuration (in Rupees) ───────────────────────────────────────
VITE_CERT_GENERATION_RATE=1
VITE_CERT_REGENERATION_RATE=1

# ─── Worker Configuration ────────────────────────────────────────────────────
CONCURRENCY_LIMIT=4
ASYNC_CONCURRENCY=10
